# Port the server listens on
PORT=3000

# Long random string used to sign login sessions. Change this to your own random value.
JWT_SECRET=change-this-to-a-long-random-string

# From your Google Cloud service account JSON key file
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The ID from your Google Sheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SHEET_ID=your-google-sheet-id

# Outlook / Microsoft 365 mailbox used to send task-assignment notifications.
# This must be a real mailbox in your company's Microsoft 365 tenant.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=nexus-notifications@yourcompany.com
SMTP_PASS=the-mailbox-password-or-app-password
SMTP_FROM_NAME=Nexus
